COMPOSE_PROJECT_NAME=sudoku

PUBLIC_HOSTNAME=sudoku.endfieldhq.com
FRONTEND_URL=http://localhost:8088
VITE_API_URL=/api

NGINX_HTTP_PORT=8088

POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5433

REDIS_PASSWORD=
REDIS_PORT=6380

JWT_SECRET=change-me-before-production
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
SHUTDOWN_TIMEOUT=10s
MATCHMAKING_WINDOW=45s

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

CLOUDFLARE_TUNNEL_TOKEN=

# Current DB source for migration helpers.
# If your current app DB is still exposed on localhost:5432 via kubectl port-forward,
# this default works from Docker Desktop via host.docker.internal.
SOURCE_DATABASE_URL=postgresql://postgres:changeme@host.docker.internal:5432/appdb?sslmode=disable
