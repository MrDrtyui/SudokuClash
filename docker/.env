JWT_SECRET=7e55bc0ed14ef5056d092a4ad49015145a5892517e1fd6e0
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h
SHUTDOWN_TIMEOUT=10s
