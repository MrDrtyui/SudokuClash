# Current DB source for migration helpers.
# If your current app DB is still exposed on localhost:5432 via kubectl port-forward,
# this default works from Docker Desktop via host.docker.internal.
SOURCE_DATABASE_URL=postgresql://postgres:changeme@host.docker.internal:5432/appdb?sslmode=disable
AUTO_DUMP_ON_RUN=true
AUTO_MIGRATE_ON_RUN=true
